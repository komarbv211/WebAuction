@using WebAuction.Entities
@model List<Lot>

<h1>Lot List</h1>
<p>You can manage lots here.</p>
<a asp-action="Create" class="btn btn-primary mb-2">
    <i class="bi bi-plus-lg"></i>
    Create New Lot
</a>
<table class="table">
    <thead>
        <tr class="table-dark">
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Start Price</th>
            <th scope="col">Highest Bid</th>
            <th scope="col">Bid Count</th>
            <th scope="col">End Time</th>
            <th scope="col">Category</th>
            <th scope="col">Status</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model)
        {
            <tr class="align-middle">
                <th scope="row">@i.Id</th>
                <td>@i.Name</td>
                <td>@i.StartPrice$</td>
                <td>@i.HighestBid$</td>
                <td>@i.BidCount</td>
                <td>@i.EndTime.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@i.Category?.Name</td>
                <td>
                    @if (DateTime.Now < i.EndTime)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ended</span>
                    }

                </td>
                <td>
                    <a asp-controller="Lots" asp-action="ArchiveItem" asp-route-id="@i.Id" class="btn btn-outline-warning">
                        <i class="bi bi-archive-fill"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
<p>Count: @Model.Count</p>

<div>
    <a asp-action="Archive" class="btn btn-secondary">
        <i class="bi bi-archive-fill"></i>
        <span>Show Archived Items</span>
    </a>
</div>
